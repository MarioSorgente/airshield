# Firebase web app config (exposed to the browser via Vite).
# Get these from Firebase Console → Project settings → Your apps → Web app → SDK setup.
# These values are NOT secret (they ship to the browser); access is controlled by firestore.rules.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Admin account that can view the dashboard at /dashboard.
# Must match the email in firestore.rules (isAdmin) and a user you created in
# Firebase Console → Authentication. Used for a friendly "not authorized" check.
VITE_ADMIN_EMAIL=ms.sorgente@gmail.com

# Optional: social-proof base for the waitlist counter (position = base + signups).
# Defaults to 120 if unset.
VITE_WAITLIST_OFFSET=120
